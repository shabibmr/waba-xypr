# AWS Configuration
aws_region = "us-east-1"

# Project Configuration
project_name = "waba"
environment  = "dev"

# Network Configuration (REQUIRED - Get these from your AWS Console)
vpc_id                = "vpc-xxxxxxxxxxxxx"       # Your VPC ID
ec2_subnet_id         = "subnet-xxxxxxxxxxxxx"    # Public subnet for EC2
db_subnet_group_name  = "your-db-subnet-group"    # RDS subnet group (min 2 subnets in different AZs)

# EC2 Configuration (REQUIRED)
key_pair_name = "your-key-pair-name"              # Your EC2 key pair name (without .pem)

# Security Configuration
# IMPORTANT: Change to your IP for security (get it from: curl ifconfig.me)
ssh_allowed_ips = ["0.0.0.0/0"]  # Change to ["YOUR_IP/32"] for security

# Instance Configuration
ec2_instance_type = "t3.small"

# Database Configuration
db_name     = "whatsapp_genesys"
db_username = "postgres"
