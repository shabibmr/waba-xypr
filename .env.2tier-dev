# ============================================
# DEVELOPMENT MODE
# ============================================
NODE_ENV=development
LOG_LEVEL=debug
SKIP_AUTH=false

# ============================================
# PUBLIC URLS
# ============================================
PUBLIC_URL=http://65.2.112.193
WHATSAPP_WEBHOOK_URL=http://65.2.112.193:3009/webhook
