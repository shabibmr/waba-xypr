SESSION_SECRET=dev-session-secret

# ============================================
# RATE LIMITING (Relaxed for dev)
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# ============================================
# AGENT PORTAL
# ============================================
VITE_API_GATEWAY=http://65.2.112.193:3000
VITE_AGENT_WIDGET_URL=ws://65.2.112.193:3012
VITE_ENABLE_DEV_LOGIN=true

# ============================================
# TOKEN CACHE
# ============================================
TOKEN_CACHE_TTL=3540
JWKS_CACHE_TTL=21600

# ============================================
# MESSAGE PROCESSING
# ============================================
